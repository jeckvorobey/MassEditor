{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/webasyst-release/product.schema.json",
  "title": "Webasyst release product catalogue",
  "type": "object",
  "required": ["schema_version", "product", "published_versions", "features", "distribution"],
  "properties": {
    "schema_version": {"const": 1},
    "product": {
      "type": "object",
      "required": ["id", "slug", "type", "path", "config_path", "vendor", "current_version", "locales"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "slug": {"type": "string", "minLength": 1},
        "type": {"enum": ["app", "plugin", "widget", "theme"]},
        "path": {"type": "string", "minLength": 1},
        "config_path": {"type": "string", "minLength": 1},
        "vendor": {"type": "integer", "minimum": 1},
        "current_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "locales": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 2}},
        "backend_only": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "published_versions": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "group", "since_version", "public", "evidence"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "group": {"type": "string", "minLength": 1},
          "since_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "public": {"type": "object"},
          "limitations": {"type": "object"},
          "evidence": {"type": "array", "minItems": 1}
        },
        "additionalProperties": true
      }
    },
    "distribution": {
      "type": "object",
      "required": ["root", "required_paths"],
      "properties": {
        "root": {"type": "string", "minLength": 1},
        "required_paths": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
